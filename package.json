{
  "name": "forge-electron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "forge": "node --experimental-strip-types --experimental-transform-types src/cli/forge.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --experimental-transform-types --test \"src/**/*.test.ts\""
  },
  "main": "./out/main/index.js",
  "dependencies": {
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  }
}
